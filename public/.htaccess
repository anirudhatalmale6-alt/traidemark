RewriteEngine On

# Protect config file
<Files "config.json">
    Order allow,deny
    Deny from all
</Files>

# Route API endpoints to PHP handlers
RewriteRule ^api/claude$ api/claude.php [L,QSA]
RewriteRule ^api/stripe-checkout$ api/stripe-checkout.php [L,QSA]
RewriteRule ^api/stripe-verify$ api/stripe-verify.php [L,QSA]

# SPA: route all non-file requests to index.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
